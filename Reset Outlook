# Cerrar Outlook
Get-Process outlook -ErrorAction SilentlyContinue | Stop-Process -Force

Write-Host "Outlook cerrado."

# Detectar versión de Office instalada
$versions = @("16.0","15.0","14.0")
$foundVersion = $null

foreach ($v in $versions) {
    if (Test-Path "HKCU:\Software\Microsoft\Office\$v\Outlook") {
        $foundVersion = $v
        break
    }
}

if (-not $foundVersion) {
    Write-Host "No se encontró instalación de Outlook en registro."
    exit
}

Write-Host "Versión detectada: $foundVersion"

# Eliminar perfiles de Outlook (esto borra TODAS las cuentas)
$profilePath = "HKCU:\Software\Microsoft\Office\$foundVersion\Outlook\Profiles"
if (Test-Path $profilePath) {
    Remove-Item -Path $profilePath -Recurse -Force
    Write-Host "Perfiles eliminados."
}

# Limpiar configuración adicional (opcional pero recomendado)
$autoDiscover = "HKCU:\Software\Microsoft\Office\$foundVersion\Outlook\AutoDiscover"
if (Test-Path $autoDiscover) {
    Remove-Item -Path $autoDiscover -Recurse -Force
    Write-Host "AutoDiscover limpiado."
}

# Opcional: borrar OST (cache local)
$ostPath = "$env:LOCALAPPDATA\Microsoft\Outlook"
if (Test-Path $ostPath) {
    Remove-Item "$ostPath\*.ost" -Force -ErrorAction SilentlyContinue
    Write-Host "Archivos OST eliminados."
}

# Opcional: borrar credenciales guardadas (Windows Credential Manager)
cmdkey /list | ForEach-Object {
    if ($_ -like "*Outlook*" -or $_ -like "*Office*") {
        $target = ($_ -split ":")[1].Trim()
        cmdkey /delete:$target
    }
}

Write-Host "Credenciales limpiadas."

Write-Host "✔ Outlook quedó sin perfiles ni cuentas. Ábrelo para configurar desde cero."
